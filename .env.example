# ---- 데이터베이스 ----
POSTGRES_USER=comicai
POSTGRES_PASSWORD=comicai
POSTGRES_DB=comicai
DATABASE_URL=postgresql://comicai:comicai@localhost:5433/comicai?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO (S3 호환) ----
S3_ENDPOINT=http://localhost:9000
# 브라우저가 presigned URL로 직접 다운로드할 때 사용할 외부 host.
# 도커 외부에서 같은 머신이면 localhost:9000, 외부 도메인 노출 시 그 주소로.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=comicai
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- 보안 ----
# MASTER_KEY: API 키 암호화용 KEK (AES-256-GCM). 32바이트 base64.
# 생성:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# 세션 쿠키 서명 (32바이트 random hex 권장)
SESSION_SECRET=

# ---- 앱 ----
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- 렌더 워커 ----
# compose/full.yml은 worker 컨테이너를 분리하므로 api 쪽은 1, worker 쪽은 0.
# 로컬에서 `pnpm --filter @comicai/api dev`만 띄울 거라면 0으로 두거나, 별도로 `pnpm dev:worker`를 실행해야 렌더가 진행됨.
RENDER_WORKER_DISABLED=0
RENDER_CONCURRENCY=2

# ---- OAuth ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
API_PUBLIC_URL=http://localhost:4000

# ---- Cloudflare Tunnel (배포 시에만, profile=tunnel) ----
CLOUDFLARE_TUNNEL_TOKEN=

# ---- 백업 (profile=backup) ----
# cron expression — 매일 03:00 KST 기본.
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=14
# 컨테이너 기동 즉시 1회 실행할지(테스트용).
BACKUP_RUN_ON_START=0
