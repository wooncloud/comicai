# ---- 데이터베이스 ----
POSTGRES_USER=comicai
POSTGRES_PASSWORD=comicai
POSTGRES_DB=comicai
DATABASE_URL=postgresql://comicai:comicai@localhost:5432/comicai?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- MinIO (S3 호환) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=comicai
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- 보안 ----
# MASTER_KEY: API 키 암호화용 KEK (AES-256-GCM). 32바이트 base64.
# 생성:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# 세션 쿠키 서명 (32바이트 random hex 권장)
SESSION_SECRET=

# ---- 앱 ----
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Cloudflare Tunnel (배포 시에만) ----
CLOUDFLARE_TUNNEL_TOKEN=
