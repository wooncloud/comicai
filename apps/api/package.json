{
  "name": "@comicai/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.665.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@comicai/adapters": "workspace:*",
    "@comicai/db": "workspace:*",
    "@comicai/events": "workspace:*",
    "@comicai/types": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@types/multer": "^2.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.21.2",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.1",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@comicai/eslint-config": "workspace:^",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
