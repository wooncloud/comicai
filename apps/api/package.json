{
  "name": "@comicai/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:worker": "nest start --watch --entryFile worker",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@comicai/adapters": "workspace:*",
    "@comicai/db": "workspace:*",
    "@comicai/events": "workspace:*",
    "@comicai/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.665.0",
    "bullmq": "^5.21.2",
    "sharp": "^0.33.5",
    "ulid": "^2.3.0",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
