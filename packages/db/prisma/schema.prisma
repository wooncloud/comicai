// ComicAI Prisma 스키마

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  apiKeys  ApiKey[]
  projects Project[]
  renderJobs RenderJob[]

  @@map("users")
}

model ApiKey {
  id              String    @id
  userId          String    @map("user_id")
  provider        String
  label           String
  ciphertext      String
  nonce           String
  lastVerifiedAt  DateTime? @map("last_verified_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Project {
  id        String   @id
  userId    String   @map("user_id")
  name      String
  thumbnail String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages       Page[]
  entities    ConsistencyEntity[]

  @@index([userId, createdAt])
  @@map("projects")
}

model ConsistencyEntity {
  id          String   @id
  projectId   String   @map("project_id")
  type        String // 'style' | 'character' | 'background' | 'worldview'
  name        String
  aliases     String[] @default([])
  description String   @default("")
  refImages   Json     @default("[]") @map("ref_images")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@map("consistency_entities")
}

model Page {
  id         String   @id
  projectId  String   @map("project_id")
  order      Int
  size       Json
  background Json?
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  panels  Panel[]

  @@index([projectId, order])
  @@map("pages")
}

model Panel {
  id              String  @id
  pageId          String  @map("page_id")
  shape           Json
  conti           Json?
  text            Json    @default("{}")
  refImages       Json    @default("[]") @map("ref_images")
  currentRenderId String? @map("current_render_id")
  history         String[] @default([])

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("panels")
}

model RenderJob {
  id          String    @id
  panelId     String    @map("panel_id")
  userId      String    @map("user_id")
  model       String
  ir          Json
  status      String
  resultImage Json?     @map("result_image")
  error       Json?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  finishedAt  DateTime? @map("finished_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([panelId, createdAt])
  @@index([userId, createdAt])
  @@map("render_jobs")
}
