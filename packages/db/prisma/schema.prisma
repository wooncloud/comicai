// ComicAI Prisma 스키마

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id
  email           String    @unique
  passwordHash    String?
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  avatarStorageKey String?  @map("avatar_storage_key")
  oauthProviders  Json      @default("[]") @map("oauth_providers")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  apiKeys           ApiKey[]
  projects          Project[]
  renderJobs        RenderJob[]
  emailVerifications EmailVerification[]
  passwordResets    PasswordReset[]

  @@map("users")
}

model EmailVerification {
  id        String    @id
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model ApiKey {
  id              String    @id
  userId          String    @map("user_id")
  provider        String
  label           String
  ciphertext      String
  nonce           String
  lastVerifiedAt  DateTime? @map("last_verified_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Project {
  id              String   @id
  userId          String   @map("user_id")
  name            String
  thumbnail       String?
  defaultStyleId  String?  @map("default_style_id")
  defaultModel    String?  @map("default_model")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages       Page[]
  entities    ConsistencyEntity[]

  @@index([userId, createdAt])
  @@map("projects")
}

model ConsistencyEntity {
  id          String   @id
  projectId   String   @map("project_id")
  type        String // 'style' | 'character' | 'background' | 'worldview'
  name        String
  aliases     String[] @default([])
  description String   @default("")
  refImages   Json     @default("[]") @map("ref_images")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@map("consistency_entities")
}

model Page {
  id         String   @id
  projectId  String   @map("project_id")
  order      Int
  name            String?
  size            Json
  background      Json?
  backgroundColor String?  @map("background_color")
  createdAt       DateTime @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  panels        Panel[]
  speechBubbles SpeechBubble[]
  pageTexts     PageText[]

  @@index([projectId, order])
  @@map("pages")
}

model SpeechBubble {
  id        String   @id
  pageId    String   @map("page_id")
  variant   String   // 'ellipse' | 'rect' | 'spike' | 'polygon'
  shape     Json     // { x, y, w, h, points?, tail? }
  style     Json     @default("{}") // SpeechBubbleStyle (모양/선/채움 — 텍스트 없음)
  order     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
  @@map("speech_bubbles")
}

model PageText {
  id        String   @id
  pageId    String   @map("page_id")
  x         Float
  y         Float
  w         Float
  h         Float
  text      String   @default("")
  style     Json     @default("{}") // PageTextStyle
  order     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
  @@map("page_texts")
}

model Panel {
  id              String  @id
  pageId          String  @map("page_id")
  shape           Json
  conti           Json?
  text            Json    @default("{}")
  refImages       Json    @default("[]") @map("ref_images")
  currentRenderId String? @map("current_render_id")
  styleId         String? @map("style_id")
  history         String[] @default([])

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("panels")
}

model RenderJob {
  id          String    @id
  panelId     String    @map("panel_id")
  userId      String    @map("user_id")
  model       String
  ir          Json
  status      String
  resultImage Json?     @map("result_image")
  error       Json?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  finishedAt  DateTime? @map("finished_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([panelId, createdAt])
  @@index([userId, createdAt])
  @@map("render_jobs")
}
